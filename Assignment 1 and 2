        "import numpy as np\n",
        "\n",
        "# States\n",
        "states = [\"NoPerson\", \"Far\", \"Near\"]\n",
        "n_states = len(states)\n",
        "\n",
        "# Actions\n",
        "actions = [\"Open\", \"Close\", \"Wait\"]\n",
        "n_actions = len(actions)\n",
        "\n",
        "# Rewards matrix [state][action]\n",
        "rewards = np.array([\n",
        "    [-1, 2, 0],   # NoPerson\n",
        "    [0, 1, 2],    # Far\n",
        "    [5, -2, 1]    # Near\n",
        "])\n",
        "\n",
        "# Transition probabilities P[s][a][s']\n",
        "P = np.zeros((n_states, n_actions, n_states))\n",
        "\n",
        "# Define transitions\n",
        "# NoPerson\n",
        "P[0][0] = [1, 0, 0]  # Open\n",
        "P[0][1] = [1, 0, 0]  # Close\n",
        "P[0][2] = [0.7, 0.3, 0]  # Wait\n",
        "\n",
        "# Far\n",
        "P[1][0] = [0, 0.6, 0.4]\n",
        "P[1][1] = [0, 0.8, 0.2]\n",
        "P[1][2] = [0, 0.5, 0.5]\n",
        "\n",
        "# Near\n",
        "P[2][0] = [0, 0, 1]\n",
        "P[2][1] = [0, 0.3, 0.7]\n",
        "P[2][2] = [0, 0.4, 0.6]\n",
        "\n",
        "gamma = 0.9\n",
        "\n",
        "# Initialize policy randomly\n",
        "policy = np.random.choice(n_actions, size=n_states)\n",
        "\n",
        "def policy_evaluation(policy):\n",
        "    V = np.zeros(n_states)\n",
        "    while True:\n",
        "        delta = 0\n",
        "        for s in range(n_states):\n",
        "            v = V[s]\n",
        "            a = policy[s]\n",
        "            V[s] = sum(P[s][a][s_next] * (rewards[s][a] + gamma * V[s_next])\n",
        "                       for s_next in range(n_states))\n",
        "            delta = max(delta, abs(v - V[s]))\n",
        "        if delta < 1e-4:\n",
        "            break\n",
        "    return V\n",
        "\n",
        "def policy_improvement(V):\n",
        "    new_policy = np.zeros(n_states, dtype=int)\n",
        "    for s in range(n_states):\n",
        "        Q = []\n",
        "        for a in range(n_actions):\n",
        "            q = sum(P[s][a][s_next] * (rewards[s][a] + gamma * V[s_next])\n",
        "                    for s_next in range(n_states))\n",
        "            Q.append(q)\n",
        "        new_policy[s] = np.argmax(Q)\n",
        "    return new_policy\n",
        "\n",
        "# Policy Iteration\n",
        "while True:\n",
        "    V = policy_evaluation(policy)\n",
        "    new_policy = policy_improvement(V)\n",
        "    if np.array_equal(policy, new_policy):\n",
        "        break\n",
        "    policy = new_policy\n",
        "\n",
        "print(\"Optimal Policy:\")\n",
        "for i, s in enumerate(states):\n",
        "    print(f\"{s} -> {actions[policy[i]]}\")"
      ]
